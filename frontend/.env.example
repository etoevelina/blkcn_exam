# Copy to .env.local and fill in.

# Hard-required: chain id of the deploy target. Must match deployments/*.json.
NEXT_PUBLIC_TARGET_CHAIN_ID=421614

# Hard-required: subgraph endpoint (Studio URL after `graph deploy`).
NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/<id>/prediction-market/version/latest

# RPC URL the frontend uses for direct reads (multicall etc).
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# WalletConnect project id (Cloud → Projects → Settings → Project ID).
NEXT_PUBLIC_WC_PROJECT_ID=
